<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.CivicConnect" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan</item>
        <item name="colorPrimaryVariant">@color/cyan_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/purple_accent</item>
        <item name="colorSecondaryVariant">@color/purple_accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <!-- Text input box stroke -->
        <item name="colorControlNormal">@color/text_dim</item>
        <item name="colorControlActivated">@color/cyan</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.CivicConnect.Splash" parent="Theme.CivicConnect">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <!-- Toolbar style -->
    <style name="CivicConnect.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/bg_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- TextInputLayout outlined style with dark theme -->
    <style name="CivicConnect.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/text_dim</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_dim</item>
    </style>

    <!-- Primary button -->
    <style name="CivicConnect.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/cyan</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Chip style -->
    <style name="CivicConnect.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="chipStrokeColor">@color/text_dim</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

</resources>